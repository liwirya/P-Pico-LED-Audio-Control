# Compiled MicroPython bytecode
*.mpy

# Firmware flash file (tidak perlu di-commit, bisa diunduh dari micropython.org)
*.uf2

# Log dari Pico serial/REPL
*.log

# Bytecode cache Python di komputer kamu
__pycache__/
*.py[cod]
*$py.class

# Virtual environment (kalau pakai mpremote, rshell, ampy, dll.)
.venv/
venv/
env/
ENV/

# Distribusi & packaging
dist/
build/
*.egg-info/
*.egg

# pytest cache
.pytest_cache/

# Coverage
.coverage
htmlcov/

# Thonny (IDE yang paling umum untuk Pico)
.thonny/
thonny_port.txt

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

